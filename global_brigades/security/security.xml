<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Categoría visible para que los grupos se muestren en la UI -->
    <record id="category_gb_admin" model="ir.module.category">
        <field name="name">Global Brigades</field>
        <field name="description">Access groups for Global Brigades module</field>
        <field name="sequence">10</field>
    </record>

    <!-- ========================================= -->
    <!-- GRUPOS DE SEGURIDAD -->
    <!-- ========================================= -->

    <!-- Admin - Control Total -->
    <record id="group_gb_admin" model="res.groups">
        <field name="name">GB / Admin</field>
        <field name="category_id" ref="category_gb_admin"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <!-- Program Advisors - Gestión de Rosters y Vuelos -->
    <record id="group_gb_program_advisor" model="res.groups">
        <field name="name">GB / Program Advisor</field>
        <field name="category_id" ref="category_gb_admin"/>
    </record>

    <!-- Operativo/Programático 1 - Gestión Operativa Completa -->
    <record id="group_gb_operative_1" model="res.groups">
        <field name="name">GB / Operativo Programático 1</field>
        <field name="category_id" ref="category_gb_admin"/>
    </record>

    <!-- Operativo/Programático 2 - Gestión Programática Limitada -->
    <record id="group_gb_operative_2" model="res.groups">
        <field name="name">GB / Operativo Programático 2</field>
        <field name="category_id" ref="category_gb_admin"/>
    </record>
</odoo>
