<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Acción del wizard -->
        <record id="action_partner_excel_import" model="ir.actions.act_window">
            <field name="name">LT Importar Participantes Excel</field>
            <field name="res_model">lt.partner.excel.import</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{'default_brigade_id': active_id}</field>
        </record>

        <!-- Menú PRINCIPAL - SIN PADRE (aparece en Apps > Brigadas) -->
        <menuitem id="menu_partner_excel_import"
            name="📊 LT Importar Excel"
            action="action_partner_excel_import"
            sequence="35"
            parent=""/>

        <!-- Vista del wizard -->
        <record id="view_partner_excel_import_form" model="ir.ui.view">
            <field name="name">lt.partner.excel.import.form</field>
            <field name="model">lt.partner.excel.import</field>
            <field name="arch" type="xml">
                <form string="LT Importar Participantes desde Excel">
                    <header>
                        <button name="action_import_excel" string="🚀 Importar Ahora" 
                                type="object" class="btn-primary oe_highlight"
                                attrs="{'invisible': [('state', '!=', 'ready')]}"/>
                        <button string="Finalizar" class="btn-success"
                                attrs="{'invisible': [('state', '!=', 'done')]}"
                                special="cancel"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,ready,done"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="brigade_id" options="{'no_create': True}"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="import_file" filename="filename"/>
                                <field name="filename" invisible="1"/>
                            </group>
                            <group>
                                <field name="total_lines" string="📊 Total Líneas"/>
                                <field name="imported_count" string="✅ Importados"/>
                                <field name="error_count" string="❌ Errores"/>
                            </group>
                        </group>
                        <div class="oe_structure"/>
                        <notebook>
                            <page string="📋 Vista Previa" attrs="{'invisible': [('state', '!=', 'ready')]}">
                                <div class="alert alert-info">
                                    <strong>✅ Archivo listo para importar</strong><br/>
                                    Se detectaron <field name="total_lines"/> líneas de datos.
                                </div>
                                <p class="text-muted">
                                    Columnas esperadas:<br/>
                                    A: nombre | B: apellido | C: identificación | D: email | E: teléfono
                                </p>
                            </page>
                            <page string="✅ Resultado" attrs="{'invisible': [('state', '!=', 'done')]}">
                                <div class="alert alert-success">
                                    <h4>¡Importación completada!</h4>
                                    <p><strong><field name="imported_count"/></strong> participantes creados exitosamente</p>
                                    <p>Errores: <strong><field name="error_count"/></strong></p>
                                    <field name="preview_lines" nolabel="1"/>
                                </div>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
