<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =========================================================
         BRIGADES - DETAILED REPORT (many fields & KPIs)
         ========================================================= -->
    <record id="view_gb_brigade_detailed_report_list" model="ir.ui.view">
        <field name="name">gb.brigade.detailed.report.list</field>
        <field name="model">gb.brigade</field>
        <field name="arch" type="xml">
            <list string="Brigades Detailed Report">
                <!-- Identificación general -->
                <field name="brigade_code" string="Código" optional="show"/>
                <field name="name" string="Brigada"/>
                <field name="brigade_program" string="Programa"/>
                <field name="brigade_tier" string="Tier"/>
                <field name="brigade_type" string="Tipo" optional="show"/>

                <!-- Fechas -->
                <field name="arrival_date" string="Fecha Brigada"/>
                <field name="departure_date" string="Fin Brigada" optional="show"/>

                <!-- Cliente / comunidades -->
                <field name="business_client_id" string="Cliente" optional="show"/>
                <field name="community_names" string="Comunidades" optional="show"/>

                <!-- Responsables (MANY2MANY) -->
                <field name="success_advisor_ids" widget="many2many_tags" string="Success Advisor" optional="show"/>
                <field name="coordinator_ids" widget="many2many_tags" string="Coordinador/a"/>
                <field name="program_associate_ids" widget="many2many_tags" string="Program Associate" optional="show"/>
                <field name="sending_organization_ids" widget="many2many_tags" string="Sending Org" optional="show"/>

                <!-- Voluntarios / programas / actividades -->
                <field name="volunteer_count" string="# Voluntarios" readonly="1"/>
                <field name="program_count" string="# Programs" readonly="1" optional="show"/>
                <field name="activity_count" string="# Activities" readonly="1" optional="show"/>

                <!-- Staff (totales y por tipo) -->
                <field name="staff_count" string="# Staff" readonly="1" optional="show"/>
                <field name="medical_staff_count" string="Staff Médico" readonly="1" optional="show"/>
                <field name="dental_staff_count" string="Staff Dental" readonly="1" optional="show"/>
                <field name="logistics_staff_count" string="Staff Logístico" readonly="1" optional="show"/>
                <field name="translator_staff_count" string="Traductores" readonly="1" optional="show"/>

                <!-- Logística de vuelos -->
                <field name="arrival_count" string="# Arrivals" readonly="1" optional="show"/>
                <field name="departure_count" string="# Departures" readonly="1" optional="show"/>

                <!-- Hoteles / rooming -->
                <field name="hotel_booking_count" string="# Bloques Hotel" readonly="1" optional="show"/>
                <field name="total_stay_nights" string="Noches Totales" readonly="1" optional="show"/>

                <!-- Transporte -->
                <field name="transport_count" string="# Transports" readonly="1" optional="show"/>

                <!-- Estado -->
                <field name="state" string="Estado" optional="show"/>
            </list>
        </field>
    </record>

    <!-- =========================================================
         SEARCH VIEW - DETAILED REPORT
         ========================================================= -->
    <record id="view_gb_brigade_detailed_report_search" model="ir.ui.view">
        <field name="name">gb.brigade.detailed.report.search</field>
        <field name="model">gb.brigade</field>
        <field name="arch" type="xml">
            <search string="Brigades Detailed Report">
                <field name="name" string="Brigada"/>
                <field name="brigade_code" string="Código"/>
                <field name="brigade_program" string="Programa"/>
                <field name="brigade_tier" string="Tier"/>
                <field name="brigade_type" string="Tipo"/>
                <field name="business_client_id" string="Cliente"/>
                <field name="coordinator_ids" string="Coordinador/a"/>
                <field name="program_associate_ids" string="Program Associate"/>
                <field name="success_advisor_ids" string="Success Advisor"/>
                <field name="sending_organization_ids" string="Sending Org"/>
                <field name="arrival_date" string="Fecha Brigada"/>

                <!-- Filtros rápidos por estado -->
                <filter name="state_planned"
                        string="Planned"
                        domain="[('state','=','planned')]"/>
                <filter name="state_ready"
                        string="Ready"
                        domain="[('state','=','ready')]"/>
                <filter name="state_in_field"
                        string="In Field"
                        domain="[('state','=','in_field')]"/>
                <filter name="state_completed"
                        string="Completed"
                        domain="[('state','=','completed')]"/>

                <separator/>

                <!-- Agrupaciones útiles -->
                <group expand="0" string="Agrupar por">
                    <filter name="group_program"
                            string="Programa"
                            context="{'group_by': 'brigade_program'}"/>
                    <filter name="group_tier"
                            string="Tier"
                            context="{'group_by': 'brigade_tier'}"/>
                    <filter name="group_type"
                            string="Tipo"
                            context="{'group_by': 'brigade_type'}"/>
                    <filter name="group_client"
                            string="Cliente"
                            context="{'group_by': 'business_client_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- =========================================================
         ACTION - DETAILED REPORT
         ========================================================= -->
    <record id="action_gb_brigade_detailed_report" model="ir.actions.act_window">
        <field name="name">Brigades Detailed Report</field>
        <field name="res_model">gb.brigade</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="view_id" ref="view_gb_brigade_detailed_report_list"/>
        <field name="search_view_id" ref="view_gb_brigade_detailed_report_search"/>
        <field name="help">
            Extended analytical report of brigades with communities, staff and logistics KPIs.
        </field>
    </record>

    <!-- =========================================================
         MENU - DETAILED REPORT
         (usamos el menú Reports existente como padre)
         ========================================================= -->
    <menuitem
        id="menu_gb_brigade_detailed_report"
        name="Brigades Detailed Report"
        parent="menu_gb_reports_root"
        action="action_gb_brigade_detailed_report"
        sequence="20"/>

</odoo>
