<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =========================================
         VISTAS DE COMUNIDADES
         Modelo: gb.community
    ========================================== -->

    <!-- Acción principal: Communities -->
    <record id="action_gb_community" model="ir.actions.act_window">
        <field name="name">Communities</field>
        <field name="res_model">gb.community</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- VISTA TREE / LIST -->
    <record id="view_gb_community_tree" model="ir.ui.view">
        <field name="name">gb.community.tree</field>
        <field name="model">gb.community</field>
        <field name="arch" type="xml">
            <list string="Communities">
                <field name="name"/>
                <field name="province"/>
                <field name="district"/>
                <field name="corregimiento"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- VISTA FORM -->
    <record id="view_gb_community_form" model="ir.ui.view">
        <field name="name">gb.community.form</field>
        <field name="model">gb.community</field>
        <field name="arch" type="xml">
            <form string="Community">
                <sheet>
                    <group name="general" string="General Information">
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>

                    <group name="location" string="Location">
                        <field name="province"/>
                        <field name="district"/>
                        <field name="corregimiento"/>
                    </group>

                    <group name="profile" string="Community Profile">
                        <field name="profile_pdf"/>
                        <field name="profile_link" widget="url"
                               placeholder="https://drive.google.com/..."/>
                    </group>

                    <notebook>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- =========================================
         MENÚS
         Se cuelga del menú raíz de Global Brigades
         (mismo nivel que Brigades, Hotels, Transport)
    ========================================== -->

    <!-- Menú Communities -->
    <menuitem id="menu_gb_community"
              name="Communities"
              parent="menu_gb_root"
              action="action_gb_community"
              sequence="30"
              groups="global_brigades.group_gb_pa,global_brigades.group_gb_coordinator,global_brigades.group_gb_admin"/>

</odoo>
