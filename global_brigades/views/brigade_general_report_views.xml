<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ==================== WIZARD FORM ==================== -->
        <record id="view_gb_brigade_general_report_wizard_form" model="ir.ui.view">
            <field name="name">gb.brigade.general.report.wizard.form</field>
            <field name="model">gb.brigade.general.report.wizard</field>
            <field name="arch" type="xml">
                <form string="Generate Brigade General Report">
                    <group>
                        <field name="brigade_id" required="1"/>
                    </group>
                    <footer>
                        <button name="action_generate_report" string="Generate &amp; Download" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- ==================== WIZARD ACTION ==================== -->
        <record id="action_gb_brigade_general_report_wizard" model="ir.actions.act_window">
            <field name="name">Brigade General Report</field>
            <field name="res_model">gb.brigade.general.report.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <!-- ==================== REPORT RECORD MODEL FORM ==================== -->
        <record id="view_gb_brigade_general_report_form" model="ir.ui.view">
            <field name="name">gb.brigade.general.report.form</field>
            <field name="model">gb.brigade.general.report</field>
            <field name="arch" type="xml">
                <form string="Brigade General Report" readonly="1">
                    <group>
                        <field name="brigade_id"/>
                        <field name="report_date"/>
                    </group>
                    <group>
                        <field name="excel_file" invisible="1"/>
                        <button name="generate_excel_report" string="Generate Report" type="object" class="btn-primary" invisible="excel_file"/>
                    </group>
                    <group invisible="not excel_file">
                        <field name="excel_file" widget="binary" filename="excel_filename" readonly="1"/>
                        <field name="excel_filename" readonly="1"/>
                    </group>
                </form>
            </field>
        </record>

        <!-- ==================== REPORT RECORD MODEL LIST ==================== -->
        <record id="view_gb_brigade_general_report_tree" model="ir.ui.view">
            <field name="name">gb.brigade.general.report.tree</field>
            <field name="model">gb.brigade.general.report</field>
            <field name="arch" type="xml">
                <list string="Brigade General Reports">
                    <field name="brigade_id"/>
                    <field name="report_date"/>
                    <field name="excel_filename"/>
                </list>
            </field>
        </record>

        <!-- ==================== REPORT ACTION ==================== -->
        <record id="action_gb_brigade_general_report" model="ir.actions.act_window">
            <field name="name">Brigade General Reports</field>
            <field name="res_model">gb.brigade.general.report</field>
            <field name="view_mode">tree,form</field>
        </record>

        <!-- ==================== MENU ENTRIES ==================== -->
        <menuitem
            id="menu_gb_brigade_general_report"
            name="Brigade General Report"
            parent="global_brigades.menu_gb_reports"
            action="action_gb_brigade_general_report"
            sequence="10"/>

        <!-- Quick action from Brigade form -->
        <record id="action_gb_generate_report" model="ir.actions.server">
            <field name="name">Generate General Report</field>
            <field name="model_id" ref="global_brigades.model_gb_brigade"/>
            <field name="binding_model_id" ref="global_brigades.model_gb_brigade"/>
            <field name="state">code</field>
            <field name="code">
action = env['ir.actions.act_window'].for_xml_id('global_brigades', 'action_gb_brigade_general_report_wizard')
action['context'] = dict(action.get('context', {}), default_brigade_id=record.id)
return action
            </field>
        </record>

    </data>
</odoo>
