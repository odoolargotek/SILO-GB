<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_add_participants_wizard_form" model="ir.ui.view">
    <field name="name">add.participants.wizard.form</field>
    <field name="model">gb.add.participants.wizard</field>
    <field name="arch" type="xml">
      <form string="Select Participants">
        <group>
          <field name="brigade_id" invisible="1"/>
          <field name="activity_id" invisible="1"/>
          <field name="participant_ids" widget="many2many_checkboxes"/>
        </group>
        <footer>
          <button string="Add Selected"
                  name="action_add_selected"
                  type="object"
                  class="btn-primary"/>
          <button string="Cancel" special="cancel" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_add_participants_wizard" model="ir.actions.act_window">
    <field name="name">Add Participants</field>
    <field name="res_model">gb.add.participants.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>
</odoo>
