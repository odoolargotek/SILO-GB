<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_gb_passenger_list_wizard_form" model="ir.ui.view">
        <field name="name">gb.passenger.list.wizard.form</field>
        <field name="model">gb.passenger.list.wizard</field>
        <field name="arch" type="xml">
            <form string="Passenger list">
                <sheet>
                    <group>
                        <field name="brigade_id" readonly="1"/>
                    </group>

                    <group string="Select passengers from roster">
                        <field name="passenger_ids"
                               widget="many2many_checkboxes"
                               domain="[('brigade_id', '=', brigade_id)]"
                               options="{'no_create': True, 'no_create_edit': True, 'no_quick_create': True}"/>
                        <div>
                            <span class="text-muted">
                                Si no ves nombres aquí, completa primero el Roster de la brigada.
                            </span>
                        </div>
                    </group>

                    <group string="Select staff passengers (Temp Staff)">
                        <field name="staff_ids"
                               widget="many2many_checkboxes"
                               domain="[('brigade_id', '=', brigade_id)]"
                               options="{'no_create': True, 'no_create_edit': True, 'no_quick_create': True}"/>
                        <div>
                            <span class="text-muted">
                                Solo se muestran miembros del staff temporal de esta brigada.
                            </span>
                        </div>
                    </group>
                </sheet>

                <footer>
                    <button string="Apply"
                            name="action_apply"
                            type="object"
                            class="btn-primary oe_highlight"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
