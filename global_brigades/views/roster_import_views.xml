<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- WIZARD: Import Roster from Excel -->
    <record id="view_lt_roster_import_wizard_form" model="ir.ui.view">
        <field name="name">lt.roster.import.wizard.form</field>
        <field name="model">lt.roster.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Roster from Excel">
                <div class="alert alert-info" role="alert">
                    <p>
                        <strong>Instructions:</strong> Upload an Excel file with roster member data. 
                        The system will automatically create Partner contacts and add them to this brigade's roster.
                    </p>
                    <p>
                        <strong>Download Template:</strong> Use the provided Roster Import Template to ensure correct format.
                    </p>
                </div>

                <group>
                    <group>
                        <field name="brigade_id" readonly="1"/>
                        <field name="excel_file" filename="filename" required="1"/>
                    </group>
                    <group>
                        <field name="create_partners"/>
                        <field name="skip_duplicates"/>
                        <field name="import_count" readonly="1"/>
                    </group>
                </group>

                <footer>
                    <button name="action_import_roster" type="object" string="Import Roster" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ACTION: Open Import Wizard -->
    <record id="action_lt_roster_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Roster from Excel</field>
        <field name="res_model">lt.roster.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="help">Import multiple roster members from an Excel file at once.</field>
    </record>

</odoo>
