<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- TREE: lista de ofertas de hotel -->
    <record id="view_gb_hotel_offer_tree" model="ir.ui.view">
        <field name="name">gb.hotel.offer.tree</field>
        <field name="model">gb.hotel.offer</field>
        <field name="arch" type="xml">
            <tree string="Hotel Offers">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="city"/>
                <field name="total_rooms" string="Total Habitaciones" readonly="1"/>
                <field name="total_pax" string="Total Pax (estimado)" readonly="1"/>
            </tree>
        </field>
    </record>

    <!-- FORM: detalle de oferta de hotel -->
    <record id="view_gb_hotel_offer_form" model="ir.ui.view">
        <field name="name">gb.hotel.offer.form</field>
        <field name="model">gb.hotel.offer</field>
        <field name="arch" type="xml">
            <form string="Hotel Offers">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="phone" readonly="1"/>
                            <field name="email" readonly="1"/>
                            <field name="street" readonly="1"/>
                            <field name="city" readonly="1"/>
                        </group>
                    </group>

                    <group string="RESUMEN">
                        <group>
                            <field name="total_rooms" string="Total Habitaciones" readonly="1"/>
                            <field name="total_pax" string="Total Pax (estimado)" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Pestaña Habitaciones -->
                        <page string="Habitaciones">
                            <field name="room_line_ids">
                                <tree editable="bottom" string="Habitaciones">
                                    <field name="room_number" string="Hab./Identificador"/>
                                    <field name="room_type" string="Tipo"/>
                                    <field name="bed_setup" string="Camas (detalle)"/>
                                    <field name="pax_per_room" string="Pax por habitación"/>
                                    <field name="notes" string="Notas"/>
                                </tree>
                                <form string="Habitación">
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="room_number" string="Hab./Identificador"/>
                                                <field name="room_type" string="Tipo"/>
                                            </group>
                                            <group>
                                                <field name="bed_setup" string="Camas (detalle)"/>
                                                <field name="pax_per_room" string="Pax por habitación"/>
                                            </group>
                                        </group>
                                        <group>
                                            <field name="notes" string="Notas"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_gb_hotel_offer" model="ir.actions.act_window">
        <field name="name">Hotel Offers</field>
        <field name="res_model">gb.hotel.offer</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_gb_hotel_offer_tree"/>
        <field name="help">Ofertas de alojamiento para brigadas.</field>
    </record>

    <!-- MENU (ajusta parent si tu menú raíz es otro) -->
    <menuitem
        id="menu_gb_hotel_offer"
        name="Hotel Offers"
        parent="menugbroot"
        action="action_gb_hotel_offer"
        sequence="40"
    />

</odoo>
