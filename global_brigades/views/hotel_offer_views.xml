<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- =========================================================
             LIST VIEW - Hotel Offers
           ========================================================= -->
        <record id="view_gb_hotel_offer_list_v2" model="ir.ui.view">
            <field name="name">gb.hotel.offer.list.v2</field>
            <field name="model">gb.hotel.offer</field>
            <field name="arch" type="xml">
                <list string="Hotel Offers">
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="city"/>
                    <field name="total_rooms"/>
                    <field name="total_pax"/>
                </list>
            </field>
        </record>

        <!-- =========================================================
             FORM VIEW - Hotel Offer
           ========================================================= -->
        <record id="view_gb_hotel_offer_form_v2" model="ir.ui.view">
            <field name="name">gb.hotel.offer.form.v2</field>
            <field name="model">gb.hotel.offer</field>
            <field name="arch" type="xml">
                <form string="Hotel Offer">
                    <sheet>

                        <group>
                            <field name="name"/>
                            <field name="partner_id"/>
                        </group>

                        <group>
                            <field name="phone" readonly="1"/>
                            <field name="email" readonly="1"/>
                        </group>

                        <group>
                            <field name="street" readonly="1"/>
                            <field name="city" readonly="1"/>
                        </group>

                        <separator string="RESUMEN"/>

                        <group>
                            <field name="total_rooms" readonly="1"/>
                            <field name="total_pax" readonly="1"/>
                        </group>

                        <notebook>
                            <page string="Habitaciones">
                                <field name="room_line_ids">
                                    <list editable="bottom">
                                        <!-- handle para drag & drop -->
                                        <field name="sequence" widget="handle"/>
                                        <field name="room_number"/>
                                        <field name="room_type"/>
                                        <!-- beds se calcula, no se muestra -->
                                        <field name="bed_setup"/>
                                        <field name="capacity_guess" readonly="1"/>
                                        <field name="notes"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>

                    </sheet>
                </form>
            </field>
        </record>

        <!-- =========================================================
             TREE VIEW - Habitaciones (gb.hotel.offer.room)
           ========================================================= -->
        <record id="view_gb_hotel_offer_room_tree" model="ir.ui.view">
            <field name="name">gb.hotel.offer.room.tree</field>
            <field name="model">gb.hotel.offer.room</field>
            <field name="arch" type="xml">
                <list string="Rooms">
                    <field name="sequence" widget="handle"/>
                    <field name="offer_id"/>
                    <field name="room_number"/>
                    <field name="room_type"/>
                    <!-- beds oculto -->
                    <field name="bed_setup"/>
                    <field name="capacity_guess"/>
                    <field name="notes"/>
                </list>
            </field>
        </record>

        <!-- =========================================================
             FORM VIEW - Habitación
           ========================================================= -->
        <record id="view_gb_hotel_offer_room_form" model="ir.ui.view">
            <field name="name">gb.hotel.offer.room.form</field>
            <field name="model">gb.hotel.offer.room</field>
            <field name="arch" type="xml">
                <form string="Room">
                    <sheet>
                        <group>
                            <field name="offer_id"/>
                        </group>
                        <group>
                            <field name="room_number"/>
                            <field name="room_type"/>
                        </group>
                        <group>
                            <field name="bed_setup"/>
                        </group>
                        <group>
                            <field name="capacity_guess" readonly="1"/>
                            <field name="notes"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- =========================================================
             ACTION
           ========================================================= -->
        <record id="action_gb_hotel_offer_v2" model="ir.actions.act_window">
            <field name="name">Hotel Offers</field>
            <field name="res_model">gb.hotel.offer</field>
            <field name="view_mode">list,form</field>
            <field name="target">current</field>
            <field name="view_id" ref="view_gb_hotel_offer_list_v2"/>
        </record>

        <!-- =========================================================
             MENÚS
           ========================================================= -->
        <menuitem
            id="menu_gb_hotels"
            name="Hotels"
            parent="menu_gb_root"
            sequence="30"
        />

        <menuitem
            id="menu_gb_hotel_offers"
            name="Hotel Offers"
            parent="menu_gb_hotels"
            action="action_gb_hotel_offer_v2"
            sequence="10"
        />

    </data>
</odoo>
