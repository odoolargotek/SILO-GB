<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <!-- TEST MINIMAL FORM -->
    <record id="view_gb_brigade_form_test" model="ir.ui.view">
        <field name="name">gb.brigade.form.test</field>
        <field name="model">gb.brigade</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <form string="Brigade TEST">
                <sheet>
                    <h1>
                        <field name="name" placeholder="Brigade Name"/>
                    </h1>
                    <group>
                        <group>
                            <field name="brigade_code"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="arrival_date"/>
                            <field name="departure_date"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    </data>
</odoo>