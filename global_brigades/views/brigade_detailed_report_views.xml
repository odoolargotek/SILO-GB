<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_gb_brigade_detailed_ficha" model="ir.actions.report">
        <field name="name">Brigade Detailed Report</field>
        <field name="model">gb.brigade</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">global_brigades.report_gb_brigade_detailed_ficha_template</field>
        <field name="report_file">global_brigades.report_gb_brigade_detailed_ficha_template</field>
        <field name="print_report_name">'Ficha - %s' % (object.name or '')</field>
        <field name="binding_model_id" ref="model_gb_brigade"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_gb_brigade_detailed_ficha_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">

                <t t-set="male_count" t-value="0"/>
                <t t-set="female_count" t-value="0"/>
                <t t-set="other_count" t-value="0"/>
                <t t-set="spanish_count" t-value="0"/>

                <t t-foreach="o.roster_ids" t-as="r">
                    <t t-if="r.gender == 'male'"><t t-set="male_count" t-value="male_count + 1"/></t>
                    <t t-if="r.gender == 'female'"><t t-set="female_count" t-value="female_count + 1"/></t>
                    <t t-if="r.gender and r.gender not in ['male', 'female']">
                        <t t-set="other_count" t-value="other_count + 1"/>
                    </t>
                    <t t-if="r.spanish_speaker"><t t-set="spanish_count" t-value="spanish_count + 1"/></t>
                </t>

                <t t-call="web.external_layout">
                    <div class="page">

                        <style>
                            body { font-family: Arial, sans-serif; }
                            .gb-report-title    { font-size: 16px; font-weight: 700; color: #1e3a5f; }
                            .gb-report-subtitle { font-size: 9px; color: #6b7280; }
                            .gb-report-code     { font-size: 10px; font-weight: 700; color: #374151; }
                            .gb-report-date     { font-size: 8px; color: #9ca3af; }
                            .gb-page-label      { font-size: 8px; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: .5px; }
                            .gb-section         { margin-top: 7px; }
                            .gb-avoid-break     { page-break-inside: avoid; }
                            .gb-wrap            { white-space: pre-wrap; word-break: break-word; }
                            .text-muted         { color: #6b7280; font-size: 7.5px; }
                            .gb-section-title {
                                background: #214e7a; color: #fff;
                                font-size: 9px; font-weight: 700;
                                padding: 3px 7px; text-transform: uppercase;
                                margin-bottom: 0;
                            }
                            .gb-kpi-box   { border: 1px solid #d1d5db; padding: 5px 6px; text-align: center; background: #f9fafb; }
                            .gb-kpi-value { font-size: 18px; font-weight: 700; color: #111827; }
                            .gb-kpi-label { font-size: 7.5px; color: #6b7280; text-transform: uppercase; }
                            .gb-mini-table { width: 100%; border-collapse: collapse; font-size: 8.5px; }
                            .gb-mini-table td { border: 1px solid #d1d5db; padding: 2px 5px; vertical-align: top; line-height: 1.2; }
                            .gb-label { font-weight: 700; color: #111827; background: #f3f4f6; width: 38%; }
                            .gb-table { width: 100%; border-collapse: collapse; font-size: 8px; }
                            .gb-table th {
                                background: #dbe7f3; color: #1f2937;
                                border: 1px solid #9ca3af; padding: 2px 3px;
                                text-align: left; font-weight: 700; line-height: 1.1; }
                            .gb-table td {
                                border: 1px solid #9ca3af; padding: 2px 3px;
                                vertical-align: top; line-height: 1.15; }
                            .gb-table td div, .gb-table td p { margin: 0; }
                            .gb-note-box { border: 1px solid #d1d5db; padding: 5px 7px; font-size: 8.5px; min-height: 24px; background: #fffbf0; }
                            .gb-logo     { max-width: 100px; max-height: 70px; }
                            .gb-gender-value { font-size: 20px; font-weight: 700; color: #1e3a5f; }
                            .gb-gender-label { font-size: 7.5px; text-transform: uppercase; color: #6b7280; }
                        </style>

                        <!-- HEADER -->
                        <table style="width:100%; border-collapse:collapse; margin-bottom:6px;">
                            <tr>
                                <td style="vertical-align:top; width:75%;">
                                    <div class="gb-report-title"><t t-esc="o.name or ''"/></div>
                                    <div class="gb-report-subtitle">Brigade Detailed Report
                                        <t t-if="o.lodging_facility_id"> &#183; <t t-esc="o.lodging_facility_id.display_name"/></t>
                                    </div>
                                    <div style="margin-top:2px;">
                                        <span class="gb-page-label">SUMMARY</span>
                                        <span class="gb-report-code" style="margin-left:10px;"><t t-esc="o.external_brigade_code or o.brigade_code or ''"/></span>
                                    </div>
                                </td>
                                <td style="width:25%; text-align:right; vertical-align:top;">
                                    <t t-if="o.university_logo"><img t-att-src="image_data_uri(o.university_logo)" class="gb-logo"/></t>
                                    <div class="gb-report-date" style="margin-top:3px;">Generated <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%b %d, %Y')"/></div>
                                </td>
                            </tr>
                        </table>

                        <!-- KPIs -->
                        <table style="width:100%; border-collapse:separate; border-spacing:3px 0; margin-bottom:6px;">
                            <tr>
                                <td class="gb-kpi-box"><div class="gb-kpi-value"><t t-esc="len(o.roster_ids)"/></div><div class="gb-kpi-label">Volunteers</div></td>
                                <td class="gb-kpi-box"><div class="gb-kpi-value"><t t-esc="spanish_count"/></div><div class="gb-kpi-label">Spanish Speakers</div></td>
                                <td class="gb-kpi-box"><div class="gb-kpi-value"><t t-esc="o.staff_count or 0"/></div><div class="gb-kpi-label">Staff</div></td>
                                <td class="gb-kpi-box"><div class="gb-kpi-value"><t t-esc="o.total_participants or 0"/></div><div class="gb-kpi-label">Total Participants</div></td>
                            </tr>
                        </table>

                        <!-- Brigade Info + Logistics -->
                        <table style="width:100%; border-collapse:collapse;" class="gb-avoid-break">
                            <tr>
                                <td style="width:50%; vertical-align:top; padding-right:4px;">
                                    <div class="gb-section-title">Brigade Information</div>
                                    <table class="gb-mini-table">
                                        <tr><td class="gb-label">Brigade Code</td><td><t t-esc="o.external_brigade_code or ''"/></td></tr>
                                        <tr><td class="gb-label">Internal Code</td><td><t t-esc="o.brigade_code or ''"/></td></tr>
                                        <tr><td class="gb-label">Arrival Date</td><td><t t-esc="o.arrival_date.strftime('%Y-%m-%d') if o.arrival_date else ''"/></td></tr>
                                        <tr><td class="gb-label">Departure Date</td><td><t t-esc="o.departure_date.strftime('%Y-%m-%d') if o.departure_date else ''"/></td></tr>
                                        <tr><td class="gb-label">Program</td><td><t t-esc="o.brigade_program.name if o.brigade_program else ''"/></td></tr>
                                        <tr><td class="gb-label">Brigade Type</td><td><t t-esc="dict(o._fields['brigade_type'].selection).get(o.brigade_type, o.brigade_type or '')"/></td></tr>
                                        <tr><td class="gb-label">Tier</td><td><t t-esc="dict(o._fields['brigade_tier'].selection).get(o.brigade_tier, '') if o.brigade_tier else ''"/></td></tr>
                                        <tr><td class="gb-label">Status</td><td><t t-esc="dict(o._fields['state'].selection).get(o.state, o.state or '')"/></td></tr>
                                        <tr><td class="gb-label">Restrictions</td><td><t t-esc="dict(o._fields['brigade_restriction'].selection).get(o.brigade_restriction, '') if o.brigade_restriction else ''"/></td></tr>
                                        <tr><td class="gb-label">Business Client</td><td><t t-esc="o.business_client_id.display_name if o.business_client_id else ''"/></td></tr>
                                    </table>
                                </td>
                                <td style="width:50%; vertical-align:top; padding-left:4px;">
                                    <div class="gb-section-title">Logistics and Compound</div>
                                    <table class="gb-mini-table">
                                        <tr><td class="gb-label">Lodging Facility</td><td><t t-esc="o.lodging_facility_id.display_name if o.lodging_facility_id else ''"/></td></tr>
                                        <tr><td class="gb-label">Communities</td><td class="gb-wrap"><t t-esc="o.community_names or ''"/></td></tr>
                                        <tr><td class="gb-label">Itinerary Link</td>
                                            <td class="gb-wrap">
                                                <t t-if="o.lt_itinerary_url"><a t-att-href="o.lt_itinerary_url"><t t-esc="o.lt_itinerary_url"/></a></t>
                                                <t t-elif="o.lt_itinerary_link"><t t-esc="o.lt_itinerary_link"/></t>
                                            </td></tr>
                                        <tr><td class="gb-label">Business Profile</td><td class="gb-wrap"><t t-esc="o.business_profile_link or ''"/></td></tr>
                                    </table>
                                    <div class="gb-section-title" style="margin-top:6px;">Gender Breakdown</div>
                                    <table style="width:100%; border-collapse:collapse;">
                                        <tr>
                                            <td style="text-align:center; padding:4px;">
                                                <div class="gb-gender-value"><t t-esc="male_count"/></div>
                                                <div class="gb-gender-label">Male</div>
                                            </td>
                                            <td style="text-align:center; padding:4px;">
                                                <div class="gb-gender-value"><t t-esc="female_count"/></div>
                                                <div class="gb-gender-label">Female</div>
                                            </td>
                                            <td style="text-align:center; padding:4px;">
                                                <div class="gb-gender-value"><t t-esc="other_count"/></div>
                                                <div class="gb-gender-label">Other</div>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>

                        <!-- Contacts -->
                        <div class="gb-section gb-avoid-break">
                            <div class="gb-section-title">Contacts</div>
                            <table style="width:100%; border-collapse:collapse;">
                                <tr>
                                    <td style="width:50%; vertical-align:top; padding-right:4px;">
                                        <table class="gb-mini-table">
                                            <tr><td class="gb-label">Program Advisors</td><td><t t-foreach="o.program_associate_ids" t-as="x"><div><t t-esc="x.display_name"/></div></t></td></tr>
                                            <tr><td class="gb-label">Success Advisor</td><td><t t-foreach="o.success_advisor_ids" t-as="x"><div><t t-esc="x.display_name"/></div></t></td></tr>
                                            <tr><td class="gb-label">Sending Organization</td><td><t t-foreach="o.sending_organization_ids" t-as="x"><div><t t-esc="x.display_name"/></div></t></td></tr>
                                        </table>
                                    </td>
                                    <td style="width:50%; vertical-align:top; padding-left:4px;">
                                        <table class="gb-mini-table">
                                            <tr><td class="gb-label">Lead Coordinator</td><td><t t-foreach="o.coordinator_ids" t-as="x"><div><t t-esc="x.display_name"/></div></t></td></tr>
                                            <tr><td class="gb-label">Chapter President(s)</td><td><t t-foreach="o.chapter_president_faculty_ids" t-as="x"><div><t t-esc="x.partner_id.display_name"/></div></t></td></tr>
                                            <tr><td class="gb-label">Professor / Chaperone</td><td><t t-foreach="o.professor_chaperone_ids" t-as="x"><div><t t-esc="x.partner_id.display_name"/></div></t></td></tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- Programs and Activities -->
                        <div class="gb-section">
                            <div class="gb-section-title">Program &amp; Activities</div>
                            <table class="gb-table">
                                <thead>
                                    <tr>
                                        <th style="width:20%;">Program / Activity</th>
                                        <th style="width:12%;">Type</th>
                                        <th style="width:10%;">Start</th>
                                        <th style="width:10%;">End</th>
                                        <th style="width:14%;">Place</th>
                                        <th style="width:14%;">Responsible</th>
                                        <th style="width:5%;">#</th>
                                        <th style="width:15%;">Notes</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.program_line_ids" t-as="p">
                                        <tr>
                                            <td class="gb-wrap"><t t-esc="p.program_id.display_name if p.program_id else ''"/></td>
                                            <td><t t-esc="p.program_id.name if p.program_id else ''"/></td>
                                            <td><t t-esc="p.start_date.strftime('%Y-%m-%d') if p.start_date else ''"/></td>
                                            <td><t t-esc="p.end_date.strftime('%Y-%m-%d') if p.end_date else ''"/></td>
                                            <td class="gb-wrap"><t t-esc="p.community_id.display_name if p.community_id else ''"/></td>
                                            <td class="gb-wrap"><t t-esc="p.coordinator_id.display_name if p.coordinator_id else ''"/></td>
                                            <td></td>
                                            <td class="gb-wrap"><t t-esc="p.notes or ''"/></td>
                                        </tr>
                                    </t>
                                    <t t-foreach="o.brigade_activity_ids" t-as="a">
                                        <tr>
                                            <td class="gb-wrap"><t t-esc="a.name or ''"/></td>
                                            <td><t t-foreach="a.tag_ids" t-as="tag"><div><t t-esc="tag.display_name"/></div></t></td>
                                            <td><t t-esc="a.start_datetime.strftime('%Y-%m-%d') if a.start_datetime else ''"/></td>
                                            <td><t t-esc="a.end_datetime.strftime('%Y-%m-%d') if a.end_datetime else ''"/></td>
                                            <td class="gb-wrap"><t t-esc="a.place or ''"/></td>
                                            <td class="gb-wrap"><t t-esc="a.responsible_id.display_name if a.responsible_id else ''"/></td>
                                            <td><t t-esc="a.participant_count or ''"/></td>
                                            <td class="gb-wrap"><t t-esc="a.notes or ''"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>

                        <!-- Arrivals -->
                        <div class="gb-section gb-avoid-break">
                            <div class="gb-section-title">Arrivals (<t t-esc="len(o.arrival_ids)"/>)</div>
                            <table class="gb-table">
                                <thead>
                                    <tr>
                                        <th style="width:16%;">Airline</th>
                                        <th style="width:10%;">Flight #</th>
                                        <th style="width:11%;">Date (Panama)</th>
                                        <th style="width:8%;">Time (Panama)</th>
                                        <th style="width:8%;">Through SAP</th>
                                        <th style="width:14%;">Arrival Hotel</th>
                                        <th style="width:4%;"># Pax</th>
                                        <th style="width:16%;">Passengers</th>
                                        <th style="width:13%;">Extra Charge</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.arrival_ids" t-as="arr">
                                        <tr>
                                            <td class="gb-wrap"><t t-esc="arr.title or ''"/></td>
                                            <td><t t-esc="arr.flight_number or ''"/></td>
                                            <td><t t-esc="str(arr.date) if arr.date else ''"/></td>
                                            <td><t t-esc="arr.time_slot or ''"/></td>
                                            <td style="text-align:center;"><t t-if="arr.flight_through_sap">&#10003;</t></td>
                                            <td class="gb-wrap"><t t-esc="arr.arrival_hotel_id.display_name if arr.arrival_hotel_id else ''"/></td>
                                            <td style="text-align:center;"><t t-esc="arr.n_pax or ''"/></td>
                                            <td class="gb-wrap"><t t-foreach="arr.passenger_ids" t-as="pax"><div><t t-esc="pax.partner_id.name if pax.partner_id else ''"/></div></t></td>
                                            <td class="gb-wrap"><t t-esc="arr.extra_charge or ''"/></td>
                                        </tr>
                                    </t>
                                    <t t-if="not o.arrival_ids"><tr><td colspan="9" style="text-align:center; color:#9ca3af; font-style:italic;">No arrivals registered</td></tr></t>
                                </tbody>
                            </table>
                        </div>

                        <!-- Departures -->
                        <div class="gb-section gb-avoid-break">
                            <div class="gb-section-title">Departures (<t t-esc="len(o.departure_ids)"/>)</div>
                            <table class="gb-table">
                                <thead>
                                    <tr>
                                        <th style="width:16%;">Airline</th>
                                        <th style="width:10%;">Flight #</th>
                                        <th style="width:11%;">Date (Panama)</th>
                                        <th style="width:8%;">Time (Panama)</th>
                                        <th style="width:8%;">Through SAP</th>
                                        <th style="width:14%;">Departure Hotel</th>
                                        <th style="width:4%;"># Pax</th>
                                        <th style="width:16%;">Passengers</th>
                                        <th style="width:13%;">Extra Charge</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.departure_ids" t-as="dep">
                                        <tr>
                                            <td class="gb-wrap"><t t-esc="dep.title or ''"/></td>
                                            <td><t t-esc="dep.flight_number or ''"/></td>
                                            <td><t t-esc="str(dep.date) if dep.date else ''"/></td>
                                            <td><t t-esc="dep.time_slot or ''"/></td>
                                            <td style="text-align:center;"><t t-if="dep.flight_through_sap">&#10003;</t></td>
                                            <td class="gb-wrap"><t t-esc="dep.departure_hotel_id.display_name if dep.departure_hotel_id else ''"/></td>
                                            <td style="text-align:center;"><t t-esc="dep.n_pax or ''"/></td>
                                            <td class="gb-wrap"><t t-foreach="dep.passenger_ids" t-as="pax"><div><t t-esc="pax.partner_id.name if pax.partner_id else ''"/></div></t></td>
                                            <td class="gb-wrap"><t t-esc="dep.extra_charge or ''"/></td>
                                        </tr>
                                    </t>
                                    <t t-if="not o.departure_ids"><tr><td colspan="9" style="text-align:center; color:#9ca3af; font-style:italic;">No departures registered</td></tr></t>
                                </tbody>
                            </table>
                        </div>

                        <!-- Additional Info -->
                        <div class="gb-section gb-avoid-break">
                            <div class="gb-section-title">Additional Information &amp; Observations</div>
                            <div class="gb-note-box gb-wrap"><t t-esc="o.extra_info or ''"/></div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>