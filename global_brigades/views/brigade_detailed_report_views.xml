<odoo>
    <!-- 1) Acción de reporte PDF para una brigada -->
    <report
        id="report_gb_brigade_detailed_ficha"
        model="gb.brigade"
        string="Brigade Detailed Report"
        name="global_brigades.report_gb_brigade_detailed_ficha"
        file="global_brigades.report_gb_brigade_detailed_ficha"
        report_type="qweb-pdf"
        print_report_name="'Ficha - %s' % (object.name or '')"
    />

    <!-- 2) Template QWeb básico -->
    <template id="report_gb_brigade_detailed_ficha">
        <t t-call="web.external_layout">
            <div class="page">
                <h2>
                    Brigade Ficha -
                    <t t-esc="o.name"/>
                </h2>

                <p>
                    External Brigade Code:
                    <t t-esc="o.external_brigade_code or ''"/>
                </p>

                <p>
                    Brigade Code (internal):
                    <t t-esc="o.brigade_code or ''"/>
                </p>

                <p>
                    Status:
                    <t t-esc="o.state or ''"/>
                </p>

                <p>
                    Arrival Date:
                    <t t-esc="o.arrival_date or ''"/>
                </p>

                <p>
                    Departure Date:
                    <t t-esc="o.departure_date or ''"/>
                </p>
            </div>
        </t>
    </template>

    <!-- 3) Vista heredada: SOLO insertar el botón en el header -->
    <record id="view_gb_brigade_form_inherit_report_btn" model="ir.ui.view">
        <field name="name">gb.brigade.form.inherit.report.btn</field>
        <field name="model">gb.brigade</field>
        <field name="inherit_id" ref="global_brigades.view_gb_brigade_form"/>
        <field name="arch" type="xml">
            <header position="inside">
                <button name="%(report_gb_brigade_detailed_ficha)d"
                        type="action"
                        string="Generate Detailed Report (PDF)"
                        class="btn-secondary"/>
            </header>
        </field>
    </record>
</odoo>
