<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_gb_brigade_detailed_ficha" model="ir.actions.report">
        <field name="name">Brigade Detailed Report</field>
        <field name="model">gb.brigade</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">global_brigades.report_gb_brigade_detailed_ficha_template</field>
        <field name="report_file">global_brigades.report_gb_brigade_detailed_ficha_template</field>
        <field name="print_report_name">'Ficha - %s' % (object.name or '')</field>
        <field name="binding_model_id" ref="model_gb_brigade"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_gb_brigade_detailed_ficha_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">

                <!-- COUNTERS -->
                <t t-set="male_count" t-value="0"/>
                <t t-set="female_count" t-value="0"/>
                <t t-set="other_count" t-value="0"/>
                <t t-set="spanish_count" t-value="0"/>

                <t t-set="diet_regular_count" t-value="0"/>
                <t t-set="diet_special_count" t-value="0"/>

                <t t-set="xs_count" t-value="0"/>
                <t t-set="s_count" t-value="0"/>
                <t t-set="m_count" t-value="0"/>
                <t t-set="l_count" t-value="0"/>
                <t t-set="xl_count" t-value="0"/>
                <t t-set="xxl_count" t-value="0"/>

                <t t-foreach="o.roster_ids" t-as="r">
                    <t t-if="r.gender == 'male' or r.gender == 'Male'">
                        <t t-set="male_count" t-value="male_count + 1"/>
                    </t>
                    <t t-if="r.gender == 'female' or r.gender == 'Female'">
                        <t t-set="female_count" t-value="female_count + 1"/>
                    </t>
                    <t t-if="r.gender and r.gender not in ['male', 'female', 'Male', 'Female']">
                        <t t-set="other_count" t-value="other_count + 1"/>
                    </t>

                    <t t-if="r.spanish_speaker == True or r.spanish_speaker == 'Yes'">
                        <t t-set="spanish_count" t-value="spanish_count + 1"/>
                    </t>

                    <t t-if="r.diet">
                        <t t-set="diet_special_count" t-value="diet_special_count + 1"/>
                    </t>
                    <t t-if="not r.diet">
                        <t t-set="diet_regular_count" t-value="diet_regular_count + 1"/>
                    </t>

                    <t t-if="r.tshirt_size in ['X-Small', 'XS', 'Extra Small']">
                        <t t-set="xs_count" t-value="xs_count + 1"/>
                    </t>
                    <t t-if="r.tshirt_size == 'Small'">
                        <t t-set="s_count" t-value="s_count + 1"/>
                    </t>
                    <t t-if="r.tshirt_size == 'Medium'">
                        <t t-set="m_count" t-value="m_count + 1"/>
                    </t>
                    <t t-if="r.tshirt_size == 'Large'">
                        <t t-set="l_count" t-value="l_count + 1"/>
                    </t>
                    <t t-if="r.tshirt_size in ['X-Large', 'XL']">
                        <t t-set="xl_count" t-value="xl_count + 1"/>
                    </t>
                    <t t-if="r.tshirt_size in ['XX-Large', 'XXL']">
                        <t t-set="xxl_count" t-value="xxl_count + 1"/>
                    </t>
                </t>

                <t t-call="web.external_layout">
                    <div class="page">

                        <style>
                            .gb-page-title {
                                font-size: 20px;
                                font-weight: 700;
                                color: #1e3a5f;
                                margin-bottom: 2px;
                            }
                            .gb-page-subtitle {
                                font-size: 11px;
                                color: #6b7280;
                                margin-bottom: 10px;
                            }
                            .gb-logo {
                                max-width: 120px;
                                max-height: 90px;
                            }
                            .gb-section {
                                margin-top: 12px;
                            }
                            .gb-section-title {
                                background: #214e7a;
                                color: #ffffff;
                                font-size: 12px;
                                font-weight: 700;
                                padding: 6px 8px;
                                text-transform: uppercase;
                                margin-bottom: 4px;
                            }
                            .gb-table {
                                width: 100%;
                                border-collapse: collapse;
                                font-size: 9px;
                            }
                            .gb-table th {
                                background: #dbe7f3;
                                color: #1f2937;
                                border: 1px solid #9ca3af;
                                padding: 4px 5px;
                                text-align: left;
                                font-weight: 700;
                            }
                            .gb-table td {
                                border: 1px solid #9ca3af;
                                padding: 4px 5px;
                                vertical-align: top;
                            }
                            .gb-mini-table {
                                width: 100%;
                                border-collapse: collapse;
                                font-size: 9px;
                            }
                            .gb-mini-table td,
                            .gb-mini-table th {
                                border: 1px solid #9ca3af;
                                padding: 4px 5px;
                                vertical-align: top;
                            }
                            .gb-mini-table th {
                                background: #e8eef5;
                                text-align: left;
                                font-weight: 700;
                            }
                            .gb-label {
                                font-weight: 700;
                                color: #111827;
                                width: 38%;
                            }
                            .gb-wrap {
                                white-space: pre-wrap;
                                word-break: break-word;
                            }
                            .gb-kpi {
                                width: 100%;
                                border-collapse: collapse;
                                font-size: 10px;
                            }
                            .gb-kpi td {
                                border: 1px solid #9ca3af;
                                padding: 6px;
                                text-align: center;
                            }
                            .gb-kpi-label {
                                font-size: 9px;
                                color: #374151;
                                text-transform: uppercase;
                            }
                            .gb-kpi-value {
                                font-size: 16px;
                                font-weight: 700;
                                color: #111827;
                            }
                            .gb-note-box {
                                border: 1px solid #9ca3af;
                                padding: 8px;
                                font-size: 9px;
                            }
                            .gb-avoid-break {
                                page-break-inside: avoid;
                            }
                            .gb-tight td, .gb-tight th {
                                padding: 3px 4px;
                            }
                        </style>

                        <!-- HEADER -->
                        <table style="width:100%; border-collapse:collapse; margin-bottom: 8px;">
                            <tr>
                                <td style="width:78%; vertical-align:top;">
                                    <div class="gb-page-title">
                                        <t t-esc="o.name or ''"/>
                                    </div>
                                    <div class="gb-page-subtitle">
                                        Brigade Detailed Report
                                    </div>
                                </td>
                                <td style="width:22%; text-align:right; vertical-align:top;">
                                    <t t-if="o.university_logo">
                                        <img t-att-src="image_data_uri(o.university_logo)" class="gb-logo"/>
                                    </t>
                                </td>
                            </tr>
                        </table>

                        <!-- TOP SUMMARY -->
                        <div class="gb-section gb-avoid-break">
                            <table style="width:100%; border-collapse:collapse;">
                                <tr>
                                    <td style="width:52%; vertical-align:top; padding-right:4px;">
                                        <table class="gb-mini-table">
                                            <tr>
                                                <th colspan="2">Brigade Information</th>
                                            </tr>
                                            <tr>
                                                <td class="gb-label">Chapter Name</td>
                                                <td><t t-esc="o.name or ''"/></td>
                                            </tr>
                                            <tr>
                                                <td class="gb-label">Brigade Code</td>
                                                <td><t t-esc="o.external_brigade_code or o.brigade_code or ''"/></td>
                                            </tr>
                                            <tr>
                                                <td class="gb-label">Internal Code</td>
                                                <td><t t-esc="o.brigade_code or ''"/></td>
                                            </tr>
                                            <tr>
                                                <td class="gb-label">Arrival Date</td>
                                                <td><t t-esc="o.arrival_date or ''"/></td>
                                            </tr>
                                            <tr>
                                                <td class="gb-label">Departure Date</td>
                                                <td><t t-esc="o.departure_date or ''"/></td>
                                            </tr>
                                            <tr>
                                                <td class="gb-label">Program</td>
                                                <td><t t-esc="o.brigade_program or ''"/></td>
                                            </tr>
                                            <tr>
                                                <td class="gb-label">Brigade Type</td>
                                                <td><t t-esc="o.brigade_type or ''"/></td>
                                            </tr>
                                            <tr>
                                                <td class="gb-label">Tier</td>
                                                <td><t t-esc="o.brigade_tier or ''"/></td>
                                            </tr>
                                            <tr>
                                                <td class="gb-label">Status</td>
                                                <td><t t-esc="o.state or ''"/></td>
                                            </tr>
                                        </table>
                                    </td>

                                    <td style="width:48%; vertical-align:top; padding-left:4px;">
                                        <table class="gb-kpi">
                                            <tr>
                                                <td style="width:50%;">
                                                    <div class="gb-kpi-label"># Volunteers</div>
                                                    <div class="gb-kpi-value"><t t-esc="o.volunteer_count or 0"/></div>
                                                </td>
                                                <td style="width:50%;">
                                                    <div class="gb-kpi-label"># Spanish Speakers</div>
                                                    <div class="gb-kpi-value"><t t-esc="spanish_count or 0"/></div>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td>
                                                    <div class="gb-kpi-label"># Staff</div>
                                                    <div class="gb-kpi-value"><t t-esc="o.staff_count or 0"/></div>
                                                </td>
                                                <td>
                                                    <div class="gb-kpi-label"># Participants</div>
                                                    <div class="gb-kpi-value"><t t-esc="o.total_participants or 0"/></div>
                                                </td>
                                            </tr>
                                        </table>

                                        <table class="gb-mini-table" style="margin-top:6px;">
                                            <tr>
                                                <th colspan="2">Contacts &amp; Logistics</th>
                                            </tr>
                                            <tr>
                                                <td class="gb-label">Business Client</td>
                                                <td><t t-esc="o.business_client_id.display_name if o.business_client_id else ''"/></td>
                                            </tr>
                                            <tr>
                                                <td class="gb-label">Lodging Facility</td>
                                                <td><t t-esc="o.lodging_facility_id.display_name if o.lodging_facility_id else ''"/></td>
                                            </tr>
                                            <tr>
                                                <td class="gb-label">Communities</td>
                                                <td class="gb-wrap"><t t-esc="o.community_names or ''"/></td>
                                            </tr>
                                            <tr>
                                                <td class="gb-label">Itinerary Link</td>
                                                <td class="gb-wrap">
                                                    <t t-if="o.lt_itinerary_url">
                                                        <t t-esc="o.lt_itinerary_url"/>
                                                    </t>
                                                    <t t-elif="o.lt_itinerary_link">
                                                        <t t-esc="o.lt_itinerary_link"/>
                                                    </t>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- TEMP STAFF + COMPOUND -->
                        <div class="gb-section">
                            <table style="width:100%; border-collapse:collapse;">
                                <tr>
                                    <td style="width:62%; vertical-align:top; padding-right:4px;">
                                        <div class="gb-section-title">Temp Staff</div>
                                        <table class="gb-table gb-tight">
                                            <thead>
                                                <tr>
                                                    <th style="width:18%;">Role</th>
                                                    <th style="width:32%;">Name / Provider</th>
                                                    <th style="width:20%;">Diet / Allergy</th>
                                                    <th style="width:15%;">Start Date</th>
                                                    <th style="width:15%;">End Date</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <t t-foreach="o.staff_ids" t-as="s">
                                                    <tr>
                                                        <td class="gb-wrap"><t t-esc="s.brigade_role_default or s.staff_role or ''"/></td>
                                                        <td class="gb-wrap">
                                                            <t t-esc="s.person_id.display_name if s.person_id else ''"/>
                                                            <t t-if="s.professional_registration">
                                                                <br/>
                                                                <span class="gb-wrap"><t t-esc="s.professional_registration"/></span>
                                                            </t>
                                                        </td>
                                                        <td class="gb-wrap">
                                                            <t t-if="s.diet"><div><strong>Diet:</strong> <t t-esc="s.diet"/></div></t>
                                                            <t t-if="s.allergy"><div><strong>Allergy:</strong> <t t-esc="s.allergy"/></div></t>
                                                        </td>
                                                        <td><t t-esc="s.start_datetime or ''"/></td>
                                                        <td><t t-esc="s.end_datetime or ''"/></td>
                                                    </tr>
                                                </t>
                                            </tbody>
                                        </table>
                                    </td>

                                    <td style="width:38%; vertical-align:top; padding-left:4px;">
                                        <div class="gb-section-title">Compound Information</div>
                                        <table class="gb-mini-table">
                                            <tr>
                                                <td class="gb-label">Compound</td>
                                                <td><t t-esc="o.lodging_facility_id.display_name if o.lodging_facility_id else ''"/></td>
                                            </tr>
                                            <tr>
                                                <td class="gb-label">Lead Coordinator</td>
                                                <td>
                                                    <t t-foreach="o.coordinator_ids" t-as="x">
                                                        <div><t t-esc="x.display_name"/></div>
                                                    </t>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td class="gb-label">Program Associate</td>
                                                <td>
                                                    <t t-foreach="o.program_associate_ids" t-as="x">
                                                        <div><t t-esc="x.display_name"/></div>
                                                    </t>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td class="gb-label">Success Advisor</td>
                                                <td>
                                                    <t t-foreach="o.success_advisor_ids" t-as="x">
                                                        <div><t t-esc="x.display_name"/></div>
                                                    </t>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td class="gb-label">Sending Organization</td>
                                                <td>
                                                    <t t-foreach="o.sending_organization_ids" t-as="x">
                                                        <div><t t-esc="x.display_name"/></div>
                                                    </t>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td class="gb-label">Chapter President(s)</td>
                                                <td>
                                                    <t t-foreach="o.chapter_president_faculty_ids" t-as="x">
                                                        <div><t t-esc="x.display_name"/></div>
                                                    </t>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td class="gb-label">Professor / Chaperone</td>
                                                <td>
                                                    <t t-foreach="o.professor_chaperone_ids" t-as="x">
                                                        <div><t t-esc="x.display_name"/></div>
                                                    </t>
                                                </td>
                                            </tr>
                                        </table>

                                        <div class="gb-section-title" style="margin-top:8px;">Genders</div>
                                        <table class="gb-mini-table">
                                            <tr>
                                                <td class="gb-label">Male</td>
                                                <td><t t-esc="male_count"/></td>
                                            </tr>
                                            <tr>
                                                <td class="gb-label">Female</td>
                                                <td><t t-esc="female_count"/></td>
                                            </tr>
                                            <tr>
                                                <td class="gb-label">Other</td>
                                                <td><t t-esc="other_count"/></td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- DIETS + TSHIRTS -->
                        <div class="gb-section gb-avoid-break">
                            <table style="width:100%; border-collapse:collapse;">
                                <tr>
                                    <td style="width:50%; vertical-align:top; padding-right:4px;">
                                        <div class="gb-section-title">Diets Summary</div>
                                        <table class="gb-mini-table">
                                            <tr>
                                                <th>Type</th>
                                                <th>Total</th>
                                            </tr>
                                            <tr>
                                                <td>Regular</td>
                                                <td><t t-esc="diet_regular_count"/></td>
                                            </tr>
                                            <tr>
                                                <td>Special</td>
                                                <td><t t-esc="diet_special_count"/></td>
                                            </tr>
                                            <tr>
                                                <td><strong>Total</strong></td>
                                                <td><strong><t t-esc="diet_regular_count + diet_special_count"/></strong></td>
                                            </tr>
                                        </table>
                                    </td>
                                    <td style="width:50%; vertical-align:top; padding-left:4px;">
                                        <div class="gb-section-title">T-Shirt Sizes</div>
                                        <table class="gb-mini-table">
                                            <tr>
                                                <th>X-Small</th>
                                                <th>Small</th>
                                                <th>Medium</th>
                                                <th>Large</th>
                                                <th>X-Large</th>
                                                <th>XX-Large</th>
                                            </tr>
                                            <tr>
                                                <td><t t-esc="xs_count"/></td>
                                                <td><t t-esc="s_count"/></td>
                                                <td><t t-esc="m_count"/></td>
                                                <td><t t-esc="l_count"/></td>
                                                <td><t t-esc="xl_count"/></td>
                                                <td><t t-esc="xxl_count"/></td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- COMMUNITY / EXTRA ACTIVITIES -->
                        <div class="gb-section">
                            <div class="gb-section-title">Community &amp;amp; Extra Activities Information</div>
                            <table class="gb-mini-table">
                                <tr>
                                    <td class="gb-label">Coordinator</td>
                                    <td>
                                        <t t-foreach="o.coordinator_ids" t-as="x">
                                            <div><t t-esc="x.display_name"/></div>
                                        </t>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="gb-label">Program Associate / Phone N°</td>
                                    <td>
                                        <t t-foreach="o.program_associate_ids" t-as="x">
                                            <div><t t-esc="x.display_name"/></div>
                                        </t>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="gb-label">Chapter President(s)</td>
                                    <td>
                                        <t t-foreach="o.chapter_president_faculty_ids" t-as="x">
                                            <div><t t-esc="x.display_name"/></div>
                                        </t>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="gb-label">Professor/Chaperone/External Researcher</td>
                                    <td>
                                        <t t-foreach="o.professor_chaperone_ids" t-as="x">
                                            <div><t t-esc="x.display_name"/></div>
                                        </t>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="gb-label">Community Names &amp;amp; Dates</td>
                                    <td class="gb-wrap"><t t-esc="o.community_names or ''"/></td>
                                </tr>
                                <tr>
                                    <td class="gb-label">Additional Information &amp;amp; Observations</td>
                                    <td class="gb-wrap"><t t-esc="o.extra_info or ''"/></td>
                                </tr>
                            </table>

                            <table class="gb-table gb-tight" style="margin-top:6px;">
                                <thead>
                                    <tr>
                                        <th style="width:18%;">Program / Activity</th>
                                        <th style="width:12%;">Type</th>
                                        <th style="width:12%;">Start</th>
                                        <th style="width:12%;">End</th>
                                        <th style="width:14%;">Place</th>
                                        <th style="width:14%;">Responsible</th>
                                        <th style="width:8%;">#</th>
                                        <th style="width:10%;">Notes</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.brigade_activity_ids" t-as="a">
                                        <tr>
                                            <td class="gb-wrap"><t t-esc="a.name or ''"/></td>
                                            <td>
                                                <t t-foreach="a.tag_ids" t-as="tag">
                                                    <div><t t-esc="tag.display_name"/></div>
                                                </t>
                                            </td>
                                            <td><t t-esc="a.start_datetime or ''"/></td>
                                            <td><t t-esc="a.end_datetime or ''"/></td>
                                            <td class="gb-wrap"><t t-esc="a.place or ''"/></td>
                                            <td class="gb-wrap"><t t-esc="a.responsible_id.display_name if a.responsible_id else ''"/></td>
                                            <td><t t-esc="a.participant_count or 0"/></td>
                                            <td class="gb-wrap"><t t-esc="a.notes or ''"/></td>
                                        </tr>
                                    </t>

                                    <t t-foreach="o.program_line_ids" t-as="p">
                                        <tr>
                                            <td class="gb-wrap"><t t-esc="p.program_id.display_name if p.program_id else ''"/></td>
                                            <td>
                                                <t t-foreach="p.topic_ids" t-as="topic">
                                                    <div><t t-esc="topic.display_name"/></div>
                                                </t>
                                            </td>
                                            <td><t t-esc="p.start_date or ''"/></td>
                                            <td><t t-esc="p.end_date or ''"/></td>
                                            <td class="gb-wrap"><t t-esc="p.community_id.display_name if p.community_id else ''"/></td>
                                            <td class="gb-wrap"><t t-esc="p.coordinator_id.display_name if p.coordinator_id else ''"/></td>
                                            <td></td>
                                            <td class="gb-wrap"><t t-esc="p.notes or ''"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>

                        <!-- ARRIVALS -->
                        <div class="gb-section">
                            <div class="gb-section-title">Arrival</div>
                            <table class="gb-table gb-tight">
                                <thead>
                                    <tr>
                                        <th style="width:12%;">Date</th>
                                        <th style="width:10%;">Flight Number</th>
                                        <th style="width:8%;">Time</th>
                                        <th style="width:6%;">#PAX</th>
                                        <th style="width:10%;">Flight Through SAP</th>
                                        <th style="width:14%;">Arrival Hotel / City</th>
                                        <th style="width:24%;">Passengers Name / Comments</th>
                                        <th style="width:8%;">Special Transport</th>
                                        <th style="width:8%;">Extra Charge</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.arrival_ids" t-as="a">
                                        <tr>
                                            <td><t t-esc="a.date_time_arrival or ''"/></td>
                                            <td><t t-esc="a.flight_number or ''"/></td>
                                            <td><t t-esc="a.date_time_arrival or ''"/></td>
                                            <td><t t-esc="a.n_pax or 0"/></td>
                                            <td><t t-esc="a.flight_through_sap or ''"/></td>
                                            <td class="gb-wrap"><t t-esc="a.arrival_hotel_id.display_name if a.arrival_hotel_id else ''"/></td>
                                            <td class="gb-wrap">
    <t t-foreach="a.passenger_ids" t-as="p">
        <span t-esc="p.display_name"/>
        <t t-if="p != a.passenger_ids[-1]">, </t>
    </t>
</td>
                                            <td class="gb-wrap"><t t-esc="a.special_transport or ''"/></td>
                                            <td class="gb-wrap"><t t-esc="a.extra_charge or ''"/></td>
                                        </tr>
                                    </t>
